# Server Configuration
PORT=5000
NODE_ENV=production

# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/rkchat

# JWT Secret (generate a strong random string)
JWT_SECRET=your_super_secret_jwt_key_here_change_this

# JWT Expiry
JWT_EXPIRES_IN=7d

# Upload Directory (relative path)
UPLOAD_DIR=uploads

# Max file size for images (in bytes) - 5MB default
MAX_IMAGE_SIZE=5242880

# CORS Origin (your frontend URL or *)
CORS_ORIGIN=*
